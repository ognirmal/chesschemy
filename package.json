{
  "name": "chesschemy",
  "version": "0.7.0",
  "description": "A TypeScript-first engine for chess and programmable chess variants.",
  "license": "MIT",
  "author": "ognirmal",
  "homepage": "https://github.com/ognirmal/chesschemy#readme",
  "bugs": {
    "url": "https://github.com/ognirmal/chesschemy/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ognirmal/chesschemy.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "docs",
    "examples",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js",
      "require": "./dist/*/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src test examples",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run clean && npm run format:check && npm run lint && npm run typecheck && npm test && npm run build",
    "publish:dry-run": "npm publish --dry-run",
    "coverage": "vitest run --coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "chess",
    "chess-engine",
    "chess-library",
    "chess-variants",
    "engine",
    "typescript",
    "board-game",
    "game-engine",
    "turn-based",
    "deterministic",
    "move-generation",
    "legal-moves",
    "fen",
    "serialization",
    "custom-pieces",
    "abilities",
    "rules-engine",
    "variant-engine"
  ],
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.4"
  }
}
