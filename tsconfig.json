{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "declaration": true,
    "declarationMap": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleDetection": "force",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "chesschemy": ["./src/index.ts"],
      "chesschemy/abilities": ["./src/abilities/index.ts"],
      "chesschemy/core": ["./src/core/index.ts"],
      "chesschemy/effects": ["./src/effects/index.ts"],
      "chesschemy/events": ["./src/events/index.ts"],
      "chesschemy/movement": ["./src/movement/index.ts"],
      "chesschemy/pieces": ["./src/pieces/index.ts"],
      "chesschemy/presets": ["./src/presets/index.ts"],
      "chesschemy/queries": ["./src/queries/index.ts"],
      "chesschemy/rules": ["./src/rules/index.ts"],
      "chesschemy/serialization": ["./src/serialization/index.ts"],
      "chesschemy/statuses": ["./src/statuses/index.ts"],
      "chesschemy/validation": ["./src/validation/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src", "test", "examples", "*.config.ts", "eslint.config.js"]
}
